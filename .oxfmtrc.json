{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "useTabs": false,
  "semi": false,
  "singleQuote": true,
  "sortImports": {},
  "ignorePatterns": ["**/*.md"],
  "sortTailwindcss": {
    "stylesheet": "src/index.css",
    "functions": ["cn", "clsx", "cva"]
  },
  "overrides": [
    {
      "files": ["docs/**"],
      "options": {
        "sortTailwindcss": {
          "stylesheet": "docs/src/app/globals.css",
          "functions": ["cn", "clsx", "cva"]
        }
      }
    }
  ]
}
